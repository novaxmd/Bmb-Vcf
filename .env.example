# Supabase (server-side only, keep secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin dashboard password (used to unlock the Command Center)
ADMIN_PASSWORD=change-me
ADMIN_USERNAME=change-me

# Extra secret mixed into admin session token signing (any random string)
SESSION_SECRET=change-me-too

# bmb tech secret code (make api)
NEXT_PUBLIC_SITE_URL=change-me-too
RESEND_FROM_EMAIL=change-me-too
RESEND_API_KEY=change-me-too
